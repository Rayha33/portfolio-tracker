# Copy this file to `.env` and adjust as needed. Every value is optional —
# the app runs fully with NO .env at all (it ships with demo data and a free,
# no-key quote source).

# Port the web server listens on (default 3000).
PORT=3000

# Path to the SQLite database file (default ./db/portfolio.db).
# It is created and seeded automatically on first run.
PORTFOLIO_DB_PATH=./db/portfolio.db

# --- Live quotes -----------------------------------------------------------
# Underlying equity quotes (and VIX history) are fetched for free from Yahoo
# Finance and FRED — no API key needed. Set this to "0" to run fully offline:
# the app then uses the marks stored with each position instead of fetching
# live prices.
ENABLE_LIVE_QUOTES=1

# Annualized risk-free rate used by the Black-Scholes option mark model.
RISK_FREE_RATE=0.045

# Fallback annualized volatility when historical vol cannot be computed.
DEFAULT_IV=0.55

# Starting capital for the Realized equity curve (default 20000).
STARTING_CAPITAL=20000
